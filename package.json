{
  "name": "vincii-canvas",
  "productName": "Vincii Canvas",
  "version": "1.3.3",
  "private": true,
  "description": "Vincii Canvas — SSH em lote, terminal interativo e automação com IA",
  "author": "Vincii <contato@vincii.com.br>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vincii-Solucoes/vincii-canvas"
  },
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "test-server": "node test/sshd-local.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "ssh2": "^1.15.0",
    "ws": "^8.21.1"
  },
  "build": {
    "appId": "br.com.vincii.canvas",
    "productName": "Vincii Canvas",
    "afterPack": "build/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "Vincii-Solucoes",
        "repo": "vincii-canvas",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "desktop/**",
      "lib/**",
      "public/**",
      "server.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  }
}
